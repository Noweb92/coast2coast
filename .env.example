# ─────────────────────────────────────────────────────────────────────
#  Environment variables — copy this file to `.env.local` (not committed)
#  and to Vercel → Project Settings → Environment Variables in production.
# ─────────────────────────────────────────────────────────────────────

# Resend API key — create at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender shown in the inbox. Until your domain is verified in Resend,
# leave this commented to use the default "onboarding@resend.dev".
# Once you verify coast2coastroofing.com.au at https://resend.com/domains,
# switch to a branded sender, e.g.:
# RESEND_FROM="Coast2Coast Roofing <quotes@coast2coastroofing.com.au>"

# Where leads land. Falls back to `business.email` in lib/site.config.js
# if unset. Use a real, monitored mailbox — replies go here.
LEAD_NOTIFY_TO=info@coast2coastroofing.com.au
